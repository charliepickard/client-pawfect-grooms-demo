---
import BaseLayout from '../layouts/BaseLayout.astro';
import config from '../config.json';

const title = `Privacy Policy | ${config.business.name}`;
const description = `How ${config.business.name} collects, uses, and protects your personal data.`;
const lastUpdated = 'May 2026';
---

<BaseLayout title={title} description={description} canonicalPath="/privacy">
  <section class="section-padded">
    <div class="container-narrow">
      <p class="text-sm uppercase tracking-wider text-primary mb-3">Legal</p>
      <h1 class="font-heading text-4xl sm:text-5xl mb-2">Privacy Policy</h1>
      <p class="text-sm text-dark/60 mb-10">Last updated: {lastUpdated}</p>

      <article class="space-y-6 text-dark/85 leading-relaxed">
        <p>
          {config.legal.businessLegalName || config.business.name} ("we", "us", "our") is committed
          to protecting your privacy. This policy explains what personal data we collect, how we
          use it, and your rights under UK GDPR and the Data Protection Act 2018.
        </p>

        <h2 class="font-heading text-2xl pt-4">Who we are</h2>
        <p>
          {config.legal.businessLegalName || config.business.name} is the data controller for the
          information we collect from you. You can contact us at
          <a href={`mailto:${config.business.email}`} class="text-primary hover:underline">{config.business.email}</a>
          or at our address: {config.business.address.street}, {config.business.address.city},
          {config.business.address.postcode}.
        </p>

        <h2 class="font-heading text-2xl pt-4">What information we collect</h2>
        <ul class="list-disc pl-6 space-y-2">
          <li>Contact details you give us when booking (name, email, phone number).</li>
          <li>Your dog's details (name, breed, age, any health or behaviour notes).</li>
          <li>Payment information (processed securely by Stripe via Cal.com — we never see your card details).</li>
          <li>Standard website analytics: pages visited, browser type, approximate location.</li>
        </ul>

        <h2 class="font-heading text-2xl pt-4">How we use your information</h2>
        <ul class="list-disc pl-6 space-y-2">
          <li>To manage your bookings and send appointment reminders.</li>
          <li>To contact you about your dog's groom (e.g., questions, running late).</li>
          <li>To process payments and refunds.</li>
          <li>To improve our website and services.</li>
        </ul>

        <h2 class="font-heading text-2xl pt-4">How long we keep it</h2>
        <p>
          Booking and customer records are kept for 6 years to comply with HMRC retention rules.
          We delete other personal data when it's no longer needed.
        </p>

        <h2 class="font-heading text-2xl pt-4">Your rights</h2>
        <p>
          You have the right to access, correct, or delete the personal data we hold about you,
          and to object to or restrict our processing of it. To exercise any of these rights,
          email <a href={`mailto:${config.business.email}`} class="text-primary hover:underline">{config.business.email}</a>.
          You also have the right to complain to the Information Commissioner's Office
          (<a href="https://ico.org.uk" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">ico.org.uk</a>).
        </p>

        <h2 class="font-heading text-2xl pt-4">Cookies</h2>
        <p>
          This website uses essential cookies only to function. If we use analytics, it is in a
          privacy-respecting, anonymised form. We do not use advertising cookies.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
