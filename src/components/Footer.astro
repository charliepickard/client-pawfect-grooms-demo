---
import config from '../config.json';
import OpeningHours from './OpeningHours.astro';

const year = new Date().getFullYear();
const { socialLinks } = config.business;
const social = [
  { key: 'instagram', label: 'Instagram', url: socialLinks.instagram },
  { key: 'facebook',  label: 'Facebook',  url: socialLinks.facebook },
  { key: 'tiktok',    label: 'TikTok',    url: socialLinks.tiktok },
].filter((s) => s.url && s.url.length > 0);
---

<footer class="bg-dark text-light/90 mt-12">
  <div class="container-wide py-12 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <h3 class="font-heading text-xl text-white mb-3">{config.business.name}</h3>
      <p class="text-sm leading-relaxed text-light/70">
        {config.business.tagline}
      </p>
    </div>

    <div>
      <h4 class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-3">
        Visit
      </h4>
      <address class="not-italic text-sm leading-relaxed text-light/80">
        {config.business.address.street}<br />
        {config.business.address.city}<br />
        {config.business.address.postcode}
      </address>
      <div class="mt-3 text-sm space-y-1">
        <a href={`tel:${config.business.phone.replace(/\s/g, '')}`} class="block hover:text-white">
          {config.business.phone}
        </a>
        <a href={`mailto:${config.business.email}`} class="block hover:text-white">
          {config.business.email}
        </a>
      </div>
    </div>

    <div>
      <h4 class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-3">
        Opening hours
      </h4>
      <OpeningHours compact />
    </div>

    <div>
      <h4 class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-3">
        Follow
      </h4>
      {social.length > 0 ? (
        <ul class="space-y-2 text-sm">
          {social.map((s) => (
            <li>
              <a href={s.url} target="_blank" rel="noopener noreferrer" class="hover:text-white">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-sm text-light/60">Coming soon</p>
      )}
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-wide py-5 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between text-xs text-light/60">
      <p>
        &copy; {year} {config.legal.businessLegalName || config.business.name}. All rights reserved.
      </p>
      <ul class="flex gap-5">
        <li><a href="/privacy" class="hover:text-white">Privacy</a></li>
        <li><a href="/terms" class="hover:text-white">Terms</a></li>
      </ul>
    </div>
  </div>
</footer>
