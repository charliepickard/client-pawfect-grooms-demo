---
import config from '../config.json';
import OpeningHours from './OpeningHours.astro';

const year = new Date().getFullYear();
const { socialLinks } = config.business;
const social = [
  { key: 'instagram', label: 'Instagram', url: socialLinks.instagram },
  { key: 'facebook',  label: 'Facebook',  url: socialLinks.facebook },
  { key: 'tiktok',    label: 'TikTok',    url: socialLinks.tiktok },
].filter((s) => s.url && s.url.length > 0);
---

<footer class="bg-dark text-white/70 mt-12">
  <div class="container-wide py-12 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">

    {/* Col 1 — Brand */}
    <div>
      <h3 class="font-heading text-xl text-white mb-3">{config.business.name}</h3>
      <p class="text-sm leading-relaxed mb-4">
        {config.business.about}
      </p>
      {social.length > 0 && (
        <ul class="flex gap-4 text-sm">
          {social.map((s) => (
            <li>
              <a href={s.url} target="_blank" rel="noopener noreferrer"
                 class="hover:text-white transition-colors">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>

    {/* Col 2 — Quick links */}
    <div>
      <h4 class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-3">
        Quick links
      </h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/"        class="hover:text-white transition-colors">Home</a></li>
        <li><a href="/services" class="hover:text-white transition-colors">Services &amp; pricing</a></li>
        <li><a href="/gallery"  class="hover:text-white transition-colors">Gallery</a></li>
        <li><a href="/about"    class="hover:text-white transition-colors">About us</a></li>
        <li><a href="/contact"  class="hover:text-white transition-colors">Contact</a></li>
        <li><a href="/book"     class="hover:text-white transition-colors font-medium text-white/90">Book an appointment</a></li>
      </ul>
    </div>

    {/* Col 3 — Visit */}
    <div>
      <h4 class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-3">
        Visit us
      </h4>
      <address class="not-italic text-sm leading-relaxed mb-3">
        {config.business.address.street}<br />
        {config.business.address.city}<br />
        {config.business.address.postcode}
      </address>
      <div class="text-sm space-y-2">
        <a href={`tel:${config.business.phone.replace(/\s/g, '')}`}
           class="flex items-center gap-2 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               class="flex-shrink-0 opacity-60">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.64 4.87 2 2 0 0 1 3.61 2.68h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.09a16 16 0 0 0 6 6l.97-.97a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03z"></path>
          </svg>
          {config.business.phone}
        </a>
        <a href={`mailto:${config.business.email}`}
           class="flex items-center gap-2 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               class="flex-shrink-0 opacity-60">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,12 2,6"></polyline>
          </svg>
          {config.business.email}
        </a>
      </div>
    </div>

    {/* Col 4 — Opening hours */}
    <div>
      <h4 class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-3">
        Opening hours
      </h4>
      <OpeningHours compact />
    </div>

  </div>

  <div class="border-t border-white/10">
    <div class="container-wide py-5 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between text-xs text-white/40">
      <p>
        &copy; {year} {config.legal.businessLegalName || config.business.name}. All rights reserved.
      </p>
      <ul class="flex gap-5">
        <li><a href="/privacy" class="hover:text-white transition-colors">Privacy policy</a></li>
        <li><a href="/terms"   class="hover:text-white transition-colors">Terms of service</a></li>
      </ul>
    </div>
  </div>
</footer>
