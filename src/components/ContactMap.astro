---
import config from '../config.json';

const { googleMapsEmbedUrl, name, address } = config.business;
const fullAddress = [address.street, address.city, address.postcode].filter(Boolean).join(', ');
---

{googleMapsEmbedUrl ? (
  <div class="rounded-brand overflow-hidden shadow-sm border border-black/5 bg-white">
    <iframe
      src={googleMapsEmbedUrl}
      title={`Map showing the location of ${name}`}
      loading="lazy"
      width="100%"
      height="420"
      style="border:0"
      allowfullscreen
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>
) : (
  <p class="text-dark/70 italic">Map will appear here once configured.</p>
)}
