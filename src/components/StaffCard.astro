---
interface Props {
  member: {
    name: string;
    role: string;
    bio: string;
    photo: string;
    qualifications?: string[];
  };
}

const { member } = Astro.props;
---

<article class="bg-white rounded-brand overflow-hidden shadow-sm border border-black/5 grid sm:grid-cols-3 gap-0">
  <div class="sm:col-span-1 bg-secondary/40">
    <img
      src={member.photo}
      alt={`${member.name}, ${member.role}`}
      loading="lazy"
      decoding="async"
      class="w-full h-72 sm:h-full object-cover"
    />
  </div>
  <div class="sm:col-span-2 p-6 sm:p-8">
    <h3 class="font-heading text-2xl mb-1">{member.name}</h3>
    <p class="text-sm uppercase tracking-wider text-primary mb-4">{member.role}</p>
    <p class="text-dark/80 leading-relaxed mb-4">{member.bio}</p>
    {member.qualifications && member.qualifications.length > 0 && (
      <div>
        <h4 class="text-xs uppercase tracking-wider text-dark/60 mb-2">Qualifications</h4>
        <ul class="space-y-1 text-sm text-dark/80">
          {member.qualifications.map((q) => (
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary mt-1 flex-shrink-0">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>{q}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</article>
