---
import ServiceCard from './ServiceCard.astro';

interface Props {
  services: Array<{
    id: string;
    name: string;
    duration: number;
    price: number;
    description: string;
    suitableFor: string;
    featured?: boolean;
  }>;
}

const { services } = Astro.props;
---

<div class="grid gap-5 sm:gap-6 sm:grid-cols-2 lg:grid-cols-3">
  {services.map((s) => <ServiceCard service={s} />)}
</div>
