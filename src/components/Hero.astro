---
import config from '../config.json';
import BookingPopupButton from './BookingPopupButton.astro';

interface Props {
  image?: string;
  title?: string;
  subtitle?: string;
}

const {
  image = config.images.hero,
  title = config.business.name,
  subtitle = config.business.tagline,
} = Astro.props;
---

<section class="relative isolate overflow-hidden">
  <div class="absolute inset-0 -z-10">
    {/* fetchpriority="high" + no lazy = best LCP per spec */}
    <img
      src={image}
      alt=""
      fetchpriority="high"
      class="w-full h-full object-cover"
      onerror="this.style.background='linear-gradient(135deg, var(--color-primary), var(--color-dark))'; this.removeAttribute('src');"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/55"></div>
  </div>

  <div class="container-wide flex items-center min-h-[78vh] sm:min-h-[88vh] py-24 sm:py-32">
    <div class="max-w-2xl text-white">
      <h1 class="font-heading text-4xl sm:text-6xl font-semibold leading-tight text-white mb-5 drop-shadow">
        {title}
      </h1>
      <p class="text-lg sm:text-2xl text-white/90 mb-8 max-w-xl">
        {subtitle}
      </p>
      <div class="flex flex-wrap gap-3">
        <BookingPopupButton label="Book an appointment" style="accent" size="lg" />
        <a href="/services" class="inline-flex items-center gap-2 px-6 py-3 rounded-brand bg-white/10 text-white font-semibold backdrop-blur border border-white/30 hover:bg-white/20 transition-colors">
          See services & pricing
        </a>
      </div>
    </div>
  </div>
</section>
