---
import config from '../config.json';
import ReviewCard from './ReviewCard.astro';

interface Props {
  heading?: string;
}

const { heading = 'What our clients say' } = Astro.props;
---

<section class="section-padded">
  <div class="container-wide">
    <div class="text-center mb-10">
      <h2 class="font-heading text-3xl sm:text-4xl">{heading}</h2>
    </div>
    <div class="grid gap-5 sm:gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {config.reviews.map((r) => <ReviewCard review={r} />)}
    </div>
  </div>
</section>
