---
import config from '../config.json';

interface Props {
  heading?: string;
  subheading?: string;
}

const {
  heading = 'Ready to book?',
  subheading,
} = Astro.props;

const note = subheading ?? config.booking.depositNote;
---

<section class="bg-secondary/60">
  <div class="container-narrow section-padded text-center">
    <h2 class="font-heading text-3xl sm:text-4xl mb-4">{heading}</h2>
    {note && <p class="text-base sm:text-lg text-dark/80 max-w-2xl mx-auto mb-8">{note}</p>}
    <a href="/book" class="btn-primary text-base sm:text-lg">
      Book online now
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>
</section>
